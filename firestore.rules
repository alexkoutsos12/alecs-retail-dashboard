rules_version = '2';

// Security rules for Alec's Dashboard Firestore.
//
// Roles (stored on users/{uid}.role):
//   - admin:   full read/write on everything, including Settings.
//   - viewer:  full read/write on reports for the modules listed in
//              users/{uid}.allowedModules. No Settings access.
//   - manager: LEGACY. Treated as admin until auth-context silently
//              migrates the doc to "admin" on next sign-in.
//
// Paste this file's contents into Firebase Console → Firestore → Rules
// whenever it changes. The file is version-controlled here so we don't
// lose history; the console is still the source of truth at runtime.

service cloud.firestore {
  match /databases/{database}/documents {
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function role() {
      return userDoc().role;
    }
    function allowedModules() {
      // Empty list if missing so `in` checks don't explode.
      return userDoc().get('allowedModules', []);
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdminLike() {
      // "manager" is legacy; treat as admin until migrated.
      return isSignedIn() && (role() == 'admin' || role() == 'manager');
    }
    function isViewer() {
      return isSignedIn() && role() == 'viewer';
    }
    function canSeeModule(mod) {
      return isAdminLike() || (isViewer() && mod in allowedModules());
    }

    // Users: self-read/write; admins can read/write anyone.
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      allow read, write: if isAdminLike();
    }

    // Reports: full module-scoped access. Anyone allowed into a module
    // can read, create, update, and delete reports in that module.
    match /reports/{reportId} {
      allow read: if isSignedIn() && canSeeModule(resource.data.module);
      allow create: if isSignedIn()
        && canSeeModule(request.resource.data.module);
      allow update: if isSignedIn()
        && canSeeModule(resource.data.module)
        && canSeeModule(request.resource.data.module);
      allow delete: if isSignedIn() && canSeeModule(resource.data.module);
    }

    match /transactions/{txnId} {
      allow read, write: if isSignedIn();
    }

    // Allowlist: only admin can list / write. Any signed-in user may
    // read a single known email doc (needed by auth-context at sign-in
    // before the user has a user doc of their own).
    match /allowedEmails/{email} {
      allow list, write: if isAdminLike();
      allow get: if isSignedIn();
    }
  }
}
